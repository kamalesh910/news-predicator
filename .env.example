# =============================================================================
# AI News Reader and Predictor — Environment Variable Reference
# =============================================================================
# Copy this file to .env and fill in values before running docker-compose up.
# Lines starting with # are comments. Do NOT commit .env to version control.
# =============================================================================

# -----------------------------------------------------------------------------
# Kafka
# -----------------------------------------------------------------------------

# Comma-separated list of Kafka broker host:port addresses.
# Inside Docker Compose use the service name; outside use localhost:9092.
KAFKA_BROKERS=kafka:9092

# Consumer group lag count (number of messages) that triggers a structured
# warning log entry from the lag monitor utility.
KAFKA_LAG_THRESHOLD=1000

# -----------------------------------------------------------------------------
# PostgreSQL
# -----------------------------------------------------------------------------

POSTGRES_HOST=postgres
POSTGRES_PORT=5432
POSTGRES_DB=ainews
POSTGRES_USER=ainews_user
# IMPORTANT: replace with a strong password before deploying
POSTGRES_PASSWORD=changeme

# -----------------------------------------------------------------------------
# Redis
# -----------------------------------------------------------------------------

# Full Redis connection URL used by the API Gateway for session storage.
REDIS_URL=redis://redis:6379

# WebSocket session time-to-live in seconds. Sessions inactive longer than
# this value are automatically evicted from Redis.
SESSION_TTL=3600

# -----------------------------------------------------------------------------
# ML / Analysis Service
# -----------------------------------------------------------------------------

# Absolute path (inside the analysis-service container) to the HuggingFace
# BERT model directory used for caste-bias inference.
BERT_MODEL_PATH=/models/bert-caste-bias

# -----------------------------------------------------------------------------
# Burst Detection / Prediction Service
# -----------------------------------------------------------------------------

# Number of articles for a given topic within the sliding window that must be
# exceeded before a Burst_Event is emitted.
BURST_THRESHOLD=50

# Sliding window size in milliseconds used by the Flink burst detection operator.
BURST_WINDOW_MS=60000

# -----------------------------------------------------------------------------
# Ingestion Service
# -----------------------------------------------------------------------------

# Maximum number of messages to hold in the in-memory buffer when the Kafka
# raw-news topic is temporarily unavailable.
INGESTION_BUFFER_LIMIT=500

# HTTP port on which the ingestion-service exposes its /health endpoint.
INGESTION_PORT=3001

# -----------------------------------------------------------------------------
# API Gateway
# -----------------------------------------------------------------------------

# Port on which the NestJS API Gateway listens for HTTP and WebSocket traffic.
API_GATEWAY_PORT=4000

# -----------------------------------------------------------------------------
# Dashboard UI
# -----------------------------------------------------------------------------

# Base URL (HTTP/WS) that the Next.js dashboard uses to reach the API Gateway.
# In production replace with the public hostname / load-balancer address.
API_GATEWAY_URL=http://localhost:4000

# Port on which the Next.js server listens.
DASHBOARD_PORT=3000
