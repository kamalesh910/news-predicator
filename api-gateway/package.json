{
  "name": "api-gateway",
  "version": "1.0.0",
  "description": "API Gateway microservice — WebSocket, Kafka consumer, REST endpoints",
  "main": "dist/main.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/main.js",
    "start:dev": "ts-node src/main.ts",
    "test": "jest --runInBand --passWithNoTests"
  },
  "dependencies": {
    "@nestjs/common": "10.3.9",
    "@nestjs/core": "10.3.9",
    "@nestjs/platform-express": "10.3.9",
    "@nestjs/websockets": "10.3.9",
    "@nestjs/platform-socket.io": "10.3.9",
    "class-transformer": "0.5.1",
    "class-validator": "0.14.1",
    "ioredis": "5.4.1",
    "kafkajs": "2.2.4",
    "pg": "8.12.0",
    "reflect-metadata": "0.2.2",
    "rxjs": "7.8.1",
    "winston": "3.13.0"
  },
  "devDependencies": {
    "@nestjs/testing": "10.3.9",
    "@types/jest": "29.5.12",
    "@types/node": "20.14.9",
    "@types/pg": "8.11.6",
    "fast-check": "3.20.0",
    "jest": "29.7.0",
    "ts-jest": "29.2.2",
    "ts-node": "10.9.2",
    "typescript": "5.5.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
