{
  "name": "ingestion-service",
  "version": "1.0.0",
  "description": "News and social media ingestion microservice",
  "main": "dist/index.js",
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "dev": "ts-node src/index.ts",
    "test": "jest --runInBand"
  },
  "dependencies": {
    "axios": "1.7.2",
    "kafkajs": "2.2.4",
    "uuid": "10.0.0",
    "winston": "3.13.0",
    "ws": "^8.18.0"
  },
  "devDependencies": {
    "@types/jest": "29.5.12",
    "@types/node": "20.14.9",
    "@types/uuid": "10.0.0",
    "@types/ws": "^8.5.12",
    "fast-check": "3.20.0",
    "jest": "29.7.0",
    "ts-jest": "29.2.2",
    "ts-node": "10.9.2",
    "typescript": "5.5.3"
  },
  "jest": {
    "preset": "ts-jest",
    "testEnvironment": "node",
    "testMatch": [
      "**/__tests__/**/*.test.ts"
    ]
  }
}
